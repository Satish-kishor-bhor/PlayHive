# Backend Environment Variables
NODE_ENV=development
PORT=5000

# Database
DATABASE_URL="postgresql://playhive:playhive_secret@localhost:5432/playhive_db"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="playhive_super_secret_jwt_key_change_in_production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="playhive_refresh_secret_change_in_production"
JWT_REFRESH_EXPIRES_IN="7d"

# Razorpay (Test Keys)
RAZORPAY_KEY_ID="rzp_test_your_key_here"
RAZORPAY_KEY_SECRET="your_razorpay_secret_here"

# SendGrid / Email
SENDGRID_API_KEY="your_sendgrid_api_key_here"
EMAIL_FROM="noreply@playhive.gg"
EMAIL_FROM_NAME="PlayHive"

# MSG91 (SMS/OTP)
MSG91_AUTH_KEY="your_msg91_key_here"
MSG91_TEMPLATE_ID="your_template_id"

# Cloudinary (File Storage)
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# Google OAuth
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"

# WhatsApp Business API
WHATSAPP_ACCESS_TOKEN="your_whatsapp_token"
WHATSAPP_PHONE_NUMBER_ID="your_phone_number_id"

# Platform Config
PLATFORM_FEE_PERCENT=10
GST_PERCENT=18
TDS_THRESHOLD=10000
TDS_PERCENT=30

# Frontend URL
FRONTEND_URL="http://localhost:3000"
